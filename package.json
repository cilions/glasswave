{
  "name": "glasswave",
  "version": "0.1.9",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Deniz",
    "url": "https://x.com/deniiiiz_i"
  },
  "types": "./packages/index.ts",
  "exports": {
    ".": "./packages/index.ts",
    "./dist/index.css": "./dist/index.css",
    "./dist/components.css": "./dist/components.css"
  },
  "publishConfig": {
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./dist/index.css": "./dist/index.css",
      "./dist/components.css": "./dist/components.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && pnpm exec postcss packages/index.css -o dist/index.css && pnpm exec postcss packages/components.css -o dist/components.css",
    "dev": "tsc --watch & pnpm exec postcss packages/index.css -o dist/index.css --watch & pnpm exec postcss packages/components.css -o dist/components.css --watch",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "postcss": "^8.5.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "postcss-cli": "^11.0.1",
    "typescript": "^5"
  }
}
